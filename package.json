{
  "name": "asora-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Asora platform - Flutter mobile app with Azure Functions backend",
  "scripts": {
    "prepare": "if [ \"$CI\" = \"true\" ]; then exit 0; fi; command -v npx >/dev/null 2>&1 && npx husky install || true",
    "format-dart": "dart format --output=none --set-exit-if-changed .",
    "format-functions": "cd functions && npm run format",
    "lint-functions": "cd functions && npm run lint",
    "format-check": "npm run format-dart && npm run format-functions",
    "lint-check": "npm run lint-functions",
    "install-functions": "cd functions && npm install",
    "build-functions": "cd functions && npm run build",
    "audit:production": "node scripts/check-npm-audit.js",
    "test-functions": "cd functions && npm run test",
    "verify:routes": "node functions/dev/verify-routes.js",
    "openapi:lint": "redocly lint api/openapi/openapi.yaml",
    "openapi:bundle": "redocly bundle api/openapi/openapi.yaml -o api/openapi/dist/openapi.json --config=api/openapi/redocly.yaml",
    "openapi:validate:examples": "ts-node tools/openapi/validate-examples.ts",
    "openapi:check:bundle": "node scripts/check-git-diff-clean.js api/openapi/dist/openapi.json",
    "openapi:gen:dart": "openapi-generator-cli generate -g dart-dio -i api/openapi/dist/openapi.json -o lib/generated/api_client --additional-properties=pubName=asora_api_client,nullableFields=true,repositoryUrl=https://github.com/AsoraKK/Asora,hideGenerationTimestamp=true && node scripts/trim-trailing-whitespace.js lib/generated/api_client",
    "openapi:check:dart": "node scripts/check-git-diff-clean.js lib/generated/api_client --ignore lib/generated/api_client/.openapi-generator/FILES",
    "openapi:test:contract": "jest -c jest.contract.config.cjs --runInBand",
    "openapi:docs": "npx @redocly/cli build-docs api/openapi/dist/openapi.json -o api/openapi/dist/index.html",
    "marketing:validate": "node scripts/cloudflare/validate-marketing-output.mjs",
    "k6:diagnose": "bash scripts/diagnose-k6-failures.sh",
    "cosmos:contract": "node scripts/validate-cosmos-contract.js --policy infra/cosmos-container-policy.json",
    "test:cosmos-contract": "node --test scripts/tests/validate-cosmos-contract.test.js",
    "routes:guard": "node scripts/validate-functions-route-guards.js --out route-inventory.json --allowlist scripts/route-guard-allowlist.json",
    "test:route-guards": "node --test scripts/tests/validate-functions-route-guards.test.js",
    "todo:triage": "node scripts/generate-todo-triage.js",
    "k6:smoke": "node scripts/run-shared-mvp-k6.mjs load/k6/smoke.js",
    "k6:feed": "node scripts/run-shared-mvp-k6.mjs load/k6/feed-read.js",
    "k6:smoke:docker": "node scripts/run-shared-mvp-k6.mjs --docker load/k6/smoke.js",
    "k6:feed:docker": "node scripts/run-shared-mvp-k6.mjs --docker load/k6/feed-read.js",
    "apply:schema": "node tools/apply_sql_to_pg.js database/migrate_to_target_schema.sql",
    "migrate:profiles": "node tools/migrate_profiles_to_postgres.js",
    "reconcile:profiles": "node tools/reconcile_profiles.js",
    "vuln:scan": "bash tools/run_vuln_scan.sh",
    "lint:api": "npm run openapi:lint"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@redocly/cli": "^2.5.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "@types/jest": "^30.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cross-fetch": "^4.1.0",
    "glob": "^13.0.6",
    "husky": "^8.0.3",
    "jest": "^30.2.0",
    "jsonpointer": "^5.0.1",
    "oasdiff": "file:tools/openapi/oasdiff",
    "openapi-client-axios": "^7.7.0",
    "playwright": "^1.60.0",
    "tesseract.js": "^7.0.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "5.5.4",
    "yaml": "^2.8.1"
  },
  "overrides": {
    "glob@10.5.0": {
      "minimatch": "9.0.9"
    },
    "fast-xml-parser": "5.9.3",
    "form-data": "4.0.6",
    "lodash": "4.18.1",
    "minimatch@^3.0.0": "3.1.5",
    "typescript": "5.5.4"
  },
  "workspaces": [
    "functions"
  ],
  "keywords": [
    "flutter",
    "dart",
    "azure-functions",
    "typescript",
    "monorepo"
  ],
  "author": "Asora Team",
  "license": "MIT"
}
