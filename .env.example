# Lythaus (formerly Asora) - local environment template
# Do not commit real secrets.

# Core data
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE_NAME=asora
RATE_LIMIT_CONTAINER=rate_limits
RATE_LIMITS_ENABLED=true

# JWT/auth
JWT_SECRET=
INVITE_CODE_PEPPER=
JWT_ISSUER=asora-auth

# Azure AD B2C validation
B2C_TENANT=
B2C_POLICY=
B2C_EXPECTED_ISSUER=
B2C_EXPECTED_AUDIENCE=

# Key Vault + B2C config fetch
KV_URL=

# Moderation
HIVE_API_KEY=

# Notifications (FCM HTTP v1)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Observability
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_INSTRUMENTATIONKEY=

# API safety / CORS
CORS_ALLOWED_ORIGINS=https://app.staging.lythaus.co,https://admin.staging.lythaus.co
ORIGIN_GATEWAY_AUTH_REQUIRED=false
ORIGIN_GATEWAY_TOKEN=

# Public build values (production)
WEB_BASE_URL=https://app.lythaus.co
API_BASE_URL=https://api.lythaus.co/api
AUTH_URL=https://api.lythaus.co/api
ADMIN_API_URL=https://admin-api.lythaus.co/api
MARKETING_BASE_URL=https://lythaus.co

# Mobile OAuth2 client hints (optional)
OAUTH2_GOOGLE_IDP_HINT=Google
OAUTH2_APPLE_IDP_HINT=Apple
OAUTH2_WORLD_IDP_HINT=World
