---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Features"
  description="Explore the features that make Lythaus a human-first publishing platform."
  canonicalPath="/features"
>
  <section class="section">
    <h1>Features</h1>
    <p>
      Lythaus is designed to make publishing calm, thoughtful, and safe.
    </p>

    <div class="grid">
      <div class="card">
        <h3>Invite-only community</h3>
        <p>
          Growth is intentional. Every member is invited by someone already in
          the community, keeping the signal-to-noise ratio high.
        </p>
      </div>

      <div class="card">
        <h3>AI-powered moderation</h3>
        <p>
          Hive AI and Azure Content Safety work together to flag harmful
          content — but humans always make the final call.
        </p>
      </div>

      <div class="card">
        <h3>Transparent ranking</h3>
        <p>
          No hidden algorithms. Posts are ranked by quality signals and
          community engagement, not by who pays the most.
        </p>
      </div>

      <div class="card">
        <h3>Cross-platform</h3>
        <p>
          Available on Android, iOS, and the web. Your account and content
          sync seamlessly across all devices.
        </p>
      </div>

      <div class="card">
        <h3>Privacy by default</h3>
        <p>
          Minimal data collection, session-scoped tokens, and no third-party
          trackers. Your data stays yours.
        </p>
      </div>

      <div class="card">
        <h3>Appeals process</h3>
        <p>
          Every moderation decision can be appealed. We believe in fairness
          and transparency at every step.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Features"
  description="Lythaus platform features — invite-only, human-first publishing."
  canonicalPath="/features"
>
  <section class="section">
    <h1>Features</h1>
    <p>
      Lythaus is built around authentic human content, transparent moderation,
      and community-driven accountability.
    </p>

    <div class="grid">
      <div class="card">
        <h3>Invite-only access</h3>
        <p>The beta is kept small to maintain quality discussion.</p>
      </div>
      <div class="card">
        <h3>Transparent moderation</h3>
        <p>Every moderation decision is logged and appealable.</p>
      </div>
      <div class="card">
        <h3>Community appeals</h3>
        <p>Members participate in reviewing contested decisions.</p>
      </div>
      <div class="card">
        <h3>Trust &amp; reputation</h3>
        <p>A trust passport tracks transparency streaks and community standing.</p>
      </div>
      <div class="card">
        <h3>AI-assisted safety</h3>
        <p>Content is screened for safety before publication.</p>
      </div>
      <div class="card">
        <h3>Cross-platform</h3>
        <p>Available on Android, iOS, and the web from a single codebase.</p>
      </div>
    </div>
  </section>
</BaseLayout>
