---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Pricing"
  description="Lythaus pricing — free during invite-only beta."
  canonicalPath="/pricing"
>
  <section class="section">
    <h1>Pricing</h1>
    <p>
      Lythaus is <strong>free during the invite-only beta</strong>. We are
      focused on building a great experience before thinking about monetisation.
    </p>

    <div class="grid">
      <div class="card">
        <h3>Beta (current)</h3>
        <p class="price">Free</p>
        <ul>
          <li>Full access to all features</li>
          <li>Create and share posts</li>
          <li>AI-powered moderation</li>
          <li>Cross-platform sync</li>
        </ul>
      </div>

      <div class="card">
        <h3>Future plans</h3>
        <p>
          We will share pricing details when the platform moves beyond beta.
          Existing beta users will be rewarded for their early support.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
