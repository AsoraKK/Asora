{
  "name": "asora-backend-functions",
  "version": "1.0.0",
  "description": "Asora platform backend Azure Functions with AI-powered moderation",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rimraf dist && tsc && tsc-alias && node scripts/write-dist-entry.cjs",
    "test": "jest --config jest.config.ts --runInBand",
    "test:coverage": "jest --config jest.config.ts --runInBand --coverage",
    "verify:dist": "node scripts/verify-dist-structure.cjs ../functions-dist.zip",
    "dsr:manual": "tsx scripts/manual-dsr-process.ts"
  },
  "dependencies": {
    "@azure/app-configuration": "^1.6.0",
    "@azure/cosmos": "^4.9.0",
    "@azure/functions": "^4.14.0",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.10.0",
    "@azure/storage-blob": "^12.33.0",
    "@azure/storage-queue": "^12.28.1",
    "applicationinsights": "^2.9.2",
    "archiver": "^7.0.1",
    "axios": "1.18.1",
    "fast-json-stable-stringify": "^2.1.0",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.3.0",
    "jose": "^5.2.0",
    "luxon": "^3.7.2",
    "pg": "^8.16.3",
    "pino": "^8.12.0",
    "uuid": "11.1.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^29.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cross-fetch": "^4.1.0",
    "form-data": "4.0.6",
    "jest": "^29.7.0",
    "nock": "^13.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsx": "^3.12.6",
    "typescript": "5.5.4"
  },
  "overrides": {
    "fast-xml-parser": "5.9.3",
    "form-data": "4.0.6",
    "glob@10.5.0": {
      "minimatch": "9.0.9"
    },
    "lodash": "4.18.1",
    "typescript": "5.5.4"
  },
  "keywords": [
    "azure-functions",
    "typescript",
    "cosmos-db",
    "jwt",
    "ai-moderation",
    "hive-ai",
    "asora"
  ],
  "author": "Asora Team",
  "license": "MIT"
}
