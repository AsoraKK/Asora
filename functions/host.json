{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  },
  "extensions": {
    "queues": {
      "messageEncoding": "none"
    }
  },
  "functionTimeout": "00:10:00",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond": 5,
        "excludedTypes": "Exception;Trace;Event"
      },
      "enableLiveMetrics": false,
      "enableDependencyTracking": true,
      "enablePerformanceCountersCollection": false
    },
    "logLevel": {
      "default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning",
      "Azure.Core": "Warning",
      "Azure.Core.1": "Warning",
      "Azure.Identity": "Warning",
      "Host.Function.Console": "Warning",
      "Host.Startup": "Warning",
      "Function.privacyDsrQueueMonitor.User": "Information",
      "Function.privacyDsrProcessor.User": "Information",
      "Function.privacy-admin-dsr-enqueue-export.User": "Information",
      "Function.privacy-admin-dsr-enqueue-delete.User": "Information"
    }
  }
}
